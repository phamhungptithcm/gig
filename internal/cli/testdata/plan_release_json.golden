        ],
        "actions": [
          {
            "code": "ABC-123:sync-source-environment",
            "summary": "ABC-123: Bring test up to date before promoting to main."
          },
          {
            "code": "ABC-123:include-missing-commits",
            "summary": "ABC-123: Include 1 missing ticket commit(s) from test into main."
          },
          {
            "code": "ABC-123:include-missing-dependency",
            "summary": "ABC-123: Include dependency ticket XYZ-456 in main before promoting ABC-123."
